{
  "name": "@netflix/x-test-cli",
  "description": "a simple cli for x-test",
  "version": "1.0.0-rc.7",
  "license": "Apache-2.0",
  "repository": "https://github.com/Netflix/x-test",
  "type": "module",
  "bin": {
    "x-test": "./x-test-cli.js"
  },
  "exports": {
    "./x-test-cli.js": "./x-test-cli.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "start": "node ./server.js",
    "lint": "eslint --max-warnings=0 .",
    "lint-fix": "eslint --fix .",
    "type": "tsc",
    "ci:setup-playwright": "playwright install --with-deps webkit",
    "test": "npm run test:node && npm run test:browser",
    "test:node": "node --test test/node/*.test.js",
    "test:browser": "npm run test:browser:puppeteer:chromium && npm run test:browser:playwright:chromium && npm run test:browser:playwright:firefox && npm run test:browser:playwright:webkit && npm run test:browser:parity",
    "test:browser:puppeteer:chromium": "node ./x-test-cli.js --client=puppeteer --browser=chromium",
    "test:browser:playwright:chromium": "playwright install chromium && node ./x-test-cli.js --client=playwright --browser=chromium",
    "test:browser:playwright:firefox": "playwright install firefox && node ./x-test-cli.js --client=playwright --browser=firefox --coverage=false",
    "test:browser:playwright:webkit": "playwright install webkit && node ./x-test-cli.js --client=playwright --browser=webkit --coverage=false",
    "test:browser:parity": "node ./test/node/parity.js",
    "demo": "node demo/index.js",
    "demo:color": "node demo/color.js",
    "demo:tap": "node demo/tap.js",
    "bump": "./bump.sh"
  },
  "files": [
    "LICENSE",
    "/x-test-cli.js",
    "/x-test-cli-browser.js",
    "/x-test-cli-config.js",
    "/x-test-cli-coverage.js",
    "/x-test-cli-tap.js",
    "/test",
    "/demo"
  ],
  "peerDependencies": {
    "@netflix/x-test": "^2.0.0-rc.6",
    "playwright": ">=1.40.0",
    "puppeteer": ">=22.0.0"
  },
  "peerDependenciesMeta": {
    "puppeteer": {
      "optional": true
    },
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@netflix/x-test": "^2.0.0-rc.6",
    "eslint": "^9.20.1",
    "eslint-plugin-jsdoc": "62.8.0",
    "playwright": "^1.59.1",
    "puppeteer": "^24.42.0",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10.8"
  },
  "contributors": [
    {
      "name": "Andrew Seier",
      "email": "aseier@netflix.com"
    },
    {
      "name": "Casey Klebba",
      "email": "cklebba@netflix.com"
    }
  ]
}
